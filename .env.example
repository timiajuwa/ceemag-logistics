# Required for /quote — production Webhook URL from n8n (workflow must be Active)
# Example: https://your-name.app.n8n.cloud/webhook/ceemag-quote
N8N_WEBHOOK_URL=

# Optional: if n8n Webhook node uses Header Auth
# N8N_WEBHOOK_AUTH_HEADER=Bearer your-token

# Optional: sent as X-Webhook-Secret; validate in n8n with an IF node
# N8N_WEBHOOK_SECRET=

# Quote page WhatsApp button (digits only, country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=19054632764

# After running `npm run images`, set to true to serve files from public/images/
# NEXT_PUBLIC_USE_LOCAL_IMAGES=true
